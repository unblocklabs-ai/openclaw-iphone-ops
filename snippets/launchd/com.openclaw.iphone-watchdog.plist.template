<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.openclaw.iphone-watchdog</string>

  <key>ProgramArguments</key>
  <array>
    <string>__REPO_DIR__/snippets/launchd/openclaw-iphone-watchdog.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>120</integer>
  <key>ProcessType</key>
  <string>Background</string>
  <key>ExitTimeOut</key>
  <integer>20</integer>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/openclaw/iphone-watchdog.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/openclaw/iphone-watchdog.err.log</string>
  <key>StandardInPath</key>
  <string>/dev/null</string>
</dict>
</plist>

# Copy this file to ~/.openclaw/iphone/config.env on each OpenClaw host.
# A repo-local .env is also supported for development and is ignored by Git.

# Optional on one-phone hosts, useful as documentation and protection if a
# second device is ever connected. Accepts device name, CoreDevice identifier,
# or physical UDID.
OPENCLAW_IPHONE_DEVICE="My iPhone"

# Canonical checkout and WebDriverAgent locations for this host.
OPENCLAW_IPHONE_REPO_DIR="$HOME/.openclaw/repos/openclaw-iphone"
OPENCLAW_IPHONE_WDA_PATH="$HOME/.openclaw/iphone/WebDriverAgent"

# Signing settings used by `openclaw-iphone wda run`. Choose a unique bundle id
# for the Apple Developer account/team used on this host.
OPENCLAW_IPHONE_RUNNER_BUNDLE_ID="com.example.openclaw.WebDriverAgentRunner"
OPENCLAW_IPHONE_DEVELOPMENT_TEAM=""
OPENCLAW_IPHONE_DESTINATION_TIMEOUT="60"

# Do not set OPENCLAW_IPHONE_WDA_URL for normal USB-connected operation.
# The CLI resolves the live CoreDevice WDA URL dynamically from the iPhone.
